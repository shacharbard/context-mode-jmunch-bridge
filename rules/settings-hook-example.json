{
  "_comment": "Add these hooks to your .claude/settings.json. The Read matcher adds context-mode-nudge.sh alongside jCodeMunch/jDocMunch hooks. The Bash matcher adds context-mode-bash-nudge.sh to redirect large-output commands.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "_comment": "jCodeMunch hook (from jmunch-claude-code-setup)",
            "type": "command",
            "command": "bash .claude/hooks/jcodemunch-nudge.sh"
          },
          {
            "_comment": "jDocMunch hook (from jmunch-claude-code-setup)",
            "type": "command",
            "command": "bash .claude/hooks/jdocmunch-nudge.sh"
          },
          {
            "_comment": "context-mode Read hook (this repo) — blocks large JSON/HTML",
            "type": "command",
            "command": "bash .claude/hooks/context-mode-nudge.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "_comment": "context-mode Bash hook (this repo) — blocks large-output commands",
            "type": "command",
            "command": "bash .claude/hooks/context-mode-bash-nudge.sh"
          }
        ]
      }
    ]
  }
}
